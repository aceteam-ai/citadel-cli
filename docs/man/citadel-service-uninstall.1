.TH "CITADEL" "1" "Jul 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-service-uninstall - Uninstall the Citadel system service


.SH SYNOPSIS
\fBcitadel service uninstall [flags]\fP


.SH DESCRIPTION
Stop and remove the Citadel managed service.

.PP
This stops the running service, disables auto-start, and removes the service
configuration file. It does NOT remove Citadel config or data.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for uninstall


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-auto-update\fP[=false]
	Disable automatic update checks and installs for this run (or set CITADEL_NO_AUTO_UPDATE=1)

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-service(1)\fP
