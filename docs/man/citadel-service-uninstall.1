.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-service-uninstall - Uninstall the Citadel system service


.SH SYNOPSIS
\fBcitadel service uninstall [flags]\fP


.SH DESCRIPTION
Uninstall the Citadel system service


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for uninstall


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-service(1)\fP
