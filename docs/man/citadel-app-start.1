.TH "CITADEL" "1" "Jul 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-app-start - Start a previously stopped app


.SH SYNOPSIS
\fBcitadel app start  [flags]\fP


.SH DESCRIPTION
Start a previously stopped app


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for start


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-app(1)\fP
