.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-service-catalog-update - Download or refresh the local service catalog


.SH SYNOPSIS
\fBcitadel service catalog update [flags]\fP


.SH DESCRIPTION
Download or refresh the local service catalog


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for update


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-service-catalog(1)\fP
