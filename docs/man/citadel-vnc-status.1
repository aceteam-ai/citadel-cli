.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-vnc-status - Show VNC server status


.SH SYNOPSIS
\fBcitadel vnc status [flags]\fP


.SH DESCRIPTION
Displays whether a VNC server is installed, running, and on which port.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for status


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-vnc(1)\fP
