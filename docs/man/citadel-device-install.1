.TH "CITADEL" "1" "Jul 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-device-install - Install the device daemon as a background service (launchd/systemd)


.SH SYNOPSIS
\fBcitadel device install [flags]\fP


.SH DESCRIPTION
Install the device daemon as a background service (launchd/systemd)


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for install


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-auto-update\fP[=false]
	Disable automatic update checks and installs for this run (or set CITADEL_NO_AUTO_UPDATE=1)

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-device(1)\fP
