.SH NAME
citadel-service-status - Show service status (alias for 'service status')


.SH SYNOPSIS
\fBcitadel service-status [flags]\fP


.SH DESCRIPTION
Show service status (alias for 'service status')


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for service-status


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel(1)\fP
