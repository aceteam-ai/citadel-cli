.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-update-rollback - Restore the previous version


.SH SYNOPSIS
\fBcitadel update rollback [flags]\fP


.SH DESCRIPTION
Restores the previously installed version of Citadel CLI.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for rollback


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-update(1)\fP
