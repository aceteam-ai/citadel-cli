.TH "CITADEL" "1" "Jul 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-provision-status - Show the status of a provisioned resource


.SH SYNOPSIS
\fBcitadel provision status  [flags]\fP


.SH DESCRIPTION
Show the status of a provisioned resource


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for status


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-provision(1)\fP
