.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-work - Start services and run the job worker (primary node command)


.SH SYNOPSIS
\fBcitadel work [flags]\fP


.SH DESCRIPTION
Unified Citadel worker that starts services and processes jobs.

.PP
This is the primary command for running a Citadel node. It:
  1. Auto-starts services from manifest (use --no-services to skip)
  2. Connects to the AceTeam API and consumes jobs via secure proxy
  3. Reports status via pub/sub (enabled by default)
  4. Subscribes to real-time config updates
  5. Starts HTTPS gateway on port 8443 (use --no-gateway to skip)
  6. Starts terminal server on port 7860 (use --no-terminal to skip)

.PP
Run 'citadel init' first to authenticate and configure the node.

.PP
Examples:
  # Run after citadel init (recommended — gateway + terminal enabled)
  citadel work

.PP
# Disable the HTTPS gateway
  citadel work --no-gateway

.PP
# Disable terminal access
  citadel work --no-terminal

.PP
# Worker only (no gateway, no terminal)
  citadel work --no-gateway --no-terminal

.PP
# Disable status publishing
  citadel work --redis-status=false

.PP
# Run without auto-starting services
  citadel work --no-services


.SH OPTIONS
\fB--api-key\fP=""
	API key for authentication (or set CITADEL_API_KEY env)

.PP
\fB--auto-detect\fP=false
\[la]Deprecated\[ra] Capabilities are now always auto-detected unless declared in citadel.yaml

.PP
\fB--auto-update\fP[=false]
	Periodically check for and install newer releases (or set CITADEL_AUTO_UPDATE=true)

.PP
\fB--auto-update-interval\fP=""
	Interval between auto-update checks, e.g. 1h, 30m (default 1h; or set CITADEL_AUTO_UPDATE_INTERVAL)

.PP
\fB--base-url\fP=""
	AceTeam API base URL (default: https://aceteam.ai, or set ACETEAM_URL env)

.PP
\fB--capabilities\fP=""
	Additional comma-separated capability tags (e.g., gpu:rtx4090,llm:llama3)

.PP
\fB--device-code\fP=""
	Device authorization code for config lookup (or set CITADEL_DEVICE_CODE env)

.PP
\fB--gateway\fP[=true]
	Start the HTTPS gateway in-process (enabled by default; use --no-gateway to disable)

.PP
\fB--gateway-bind\fP="0.0.0.0"
	Gateway bind address

.PP
\fB--gateway-cert-dir\fP=""
	Custom directory for gateway TLS certificates

.PP
\fB--gateway-port\fP=8443
	HTTPS gateway port (default: 8443)

.PP
\fB--gateway-vnc-port\fP=6080
	VNC websockify port for gateway proxy

.PP
\fB--group\fP=""
	Consumer group name (default: citadel-node- or citadel-)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for work

.PP
\fB--max-concurrency\fP=0
	Maximum concurrent jobs (0 = auto-detect from GPU count)

.PP
\fB--max-retries\fP=3
	Maximum retry attempts before DLQ

.PP
\fB--no-gateway\fP[=false]
	Disable the HTTPS gateway

.PP
\fB--no-services\fP[=false]
	Skip auto-starting services from manifest

.PP
\fB--no-terminal\fP[=false]
	Disable the terminal WebSocket server

.PP
\fB--node-name\fP=""
	Node name for status reporting (default: hostname)

.PP
\fB--poll-ms\fP=5000
	Block timeout in milliseconds

.PP
\fB--queue\fP=""
	Queue/stream name to consume from (default: jobs:v1:cpu-general)

.PP
\fB--redis-status\fP[=true]
	Enable Redis status publishing for real-time updates

.PP
\fB--ssh-sync\fP[=false]
	Enable SSH authorized_keys synchronization from AceTeam

.PP
\fB--ssh-sync-interval\fP=5
	SSH sync interval in minutes

.PP
\fB--status-channel\fP=""
	Override Redis pub/sub channel for status (default: node:status:{node-name})

.PP
\fB--status-port\fP=0
	Enable status HTTP server on port (0 = disabled)

.PP
\fB--terminal\fP[=true]
	Enable terminal WebSocket server (enabled by default; use --no-terminal to disable)

.PP
\fB--terminal-debug\fP[=false]
	Enable verbose debug logging for terminal server

.PP
\fB--terminal-host\fP=""
	Terminal server bind address (default: 0.0.0.0)

.PP
\fB--terminal-port\fP=7860
	Terminal server port (default: 7860)

.PP
\fB--workspace\fP=""
	Workspace directory for file-operation jobs (or set CITADEL_WORKSPACE env)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel(1)\fP
