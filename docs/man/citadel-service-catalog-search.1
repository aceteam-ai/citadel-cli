.SH NAME
citadel-service-catalog-search - Search for services by name, tag, or category


.SH SYNOPSIS
\fBcitadel service catalog search  [flags]\fP


.SH DESCRIPTION
Search for services by name, tag, or category


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for search


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-service-catalog(1)\fP
