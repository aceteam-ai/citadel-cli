.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-app-uninstall - Remove an app, its container, and data


.SH SYNOPSIS
\fBcitadel app uninstall  [flags]\fP


.SH DESCRIPTION
Remove an app, its container, and data


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for uninstall

.PP
\fB--keep-data\fP[=false]
	Preserve the app's data directory instead of deleting it


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-app(1)\fP
