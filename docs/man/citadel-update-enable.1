.TH "CITADEL" "1" "Jun 2026" "AceTeam" "Citadel CLI Manual"

.SH NAME
citadel-update-enable - Enable automatic update checks


.SH SYNOPSIS
\fBcitadel update enable [flags]\fP


.SH DESCRIPTION
Enables periodic update checks when running citadel work.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for enable


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable debug output

.PP
\fB--no-color\fP[=false]
	Disable colorized output


.SH SEE ALSO
\fBcitadel-update(1)\fP
